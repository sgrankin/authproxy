// authproxy config — KDL format

cache {
    dir "~/.cache/authproxy"
    max-size "100GB"
    chunk-size "4MiB"
}

service "huggingface" {
    hostname "hf"
    upstream "https://huggingface.co"
    cache true
    listen "http" "https"
    header "Authorization" "Bearer ${env:HF_TOKEN}"

    // Suppress HF's Xet hints so the client stays on the HTTP download path
    // (which this proxy caches). See README / CLAUDE.md for the rationale.
    block-response-header "X-Xet-Hash" "X-Xet-Refresh-Route" "Link"
}

service "openai" {
    hostname "openai"
    upstream "https://api.openai.com"
    listen "http" "https"
    header "Authorization" "Bearer ${env:OPENAI_API_KEY}"
}

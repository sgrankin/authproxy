// authproxy config — KDL format

cache {
    dir "~/.cache/authproxy"
    max-size "100GB"
    chunk-size "4MiB"
}

service "huggingface" {
    hostname "hf"
    upstream "https://huggingface.co"
    cache true
    listen "http" "https"
    header "Authorization" "Bearer ${env:HF_TOKEN}"

    // Enable xet passthrough: HF's CAS traffic (hosts under *.xethub.hf.co)
    // is rewritten to flow through /_proxy/<host>/ on this same hostname,
    // so clients stay on the proxy for CAS + chunk fetches and benefit
    // from the content-addressable chunk cache. See CLAUDE.md.
    adapter "xet"
}

service "openai" {
    hostname "openai"
    upstream "https://api.openai.com"
    listen "http" "https"
    header "Authorization" "Bearer ${env:OPENAI_API_KEY}"
}
